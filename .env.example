# Copy to .env.local and fill in to enable the contact form to send real emails.
# Without these, the form still works in dev and logs leads to the server console.

# Get a key at https://resend.com (free tier available)
RESEND_API_KEY=

# Where quote requests are delivered
CONTACT_TO_EMAIL=hello@jarmsmarketing.com

# Verified sender. Use Resend's onboarding@resend.dev for testing,
# or your own verified domain in production.
CONTACT_FROM_EMAIL=Jarms Website <onboarding@resend.dev>
